<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="samaBoutikPU" transaction-type="JTA">
        <jta-data-source>jdbc/samaBoutikDS</jta-data-source>

        <class>entity.Personne</class>
        <class>entity.Compte</class>
        <class>entity.Role</class>
        <class>entity.Permission</class>
        <class>entity.Profil</class>
        <class>entity.Employe</class>
        <class>entity.Famille</class>
        <class>entity.Catalogue</class>
        <class>entity.Boutique</class>
        <class>entity.Produit</class>
        <class>entity.DetailProduit</class>
        <class>entity.ActiviteCommerciale</class>
        <class>entity.Entite</class>
        <class>entity.PersonneProfil</class>

        <properties>
            <!-- ✅ Hibernate/PostgreSQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="openjpa.RuntimeUnenhancedClasses" value="supported"/>
            
            <!-- ✅ Forcer TomEE à ne pas utiliser HSQLDB -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/samaboutik"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="harouna"/>
            
        </properties>
    </persistence-unit>
</persistence>
